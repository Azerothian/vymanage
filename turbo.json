{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "out/**", ".next/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "test:coverage": {
      "dependsOn": ["^build"]
    },
    "test:e2e": {
      "dependsOn": ["build"]
    },
    "electron#build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "electron#package": {
      "dependsOn": ["electron#build"],
      "outputs": ["release/**"]
    },
    "electron#dev": {
      "dependsOn": ["web#build"],
      "cache": false,
      "persistent": true
    }
  }
}
