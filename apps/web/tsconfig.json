{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"],
      "@vymanage/ui": ["../../packages/ui/src"],
      "@vymanage/ui/*": ["../../packages/ui/src/*"],
      "@vymanage/vyos-client": ["../../packages/vyos-client/src"]
    },
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "incremental": true
  },
  "include": ["src", "next-env.d.ts", ".next/types/**/*.ts"],
  "exclude": ["node_modules", "out", ".next"]
}
